# Copy this file to .env and fill in real values. .env is gitignored.
#
#   cp .env.example .env
#
# OpenAI key: enables the gpt-4o-mini runs (tau-bench + MCP suite).
OPENAI_API_KEY=

# GitHub token: enables the live GitHub MCP demo (scripts/mcp_real_servers.py --github).
# Use a throwaway / minimally-scoped classic PAT. read-only scopes are enough for the demo.
GITHUB_PERSONAL_ACCESS_TOKEN=
